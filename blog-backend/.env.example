# =============================================================================
# blog-backend — variáveis de ambiente (template)
# Copie pra .env.local (que é gitignored) e preencha com valores reais.
# NUNCA commitar .env.local.
# =============================================================================

# Supabase (mesmo projeto do app principal — schema `blog`)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# service_role — OPCIONAL. Habilita o scheduler (Sprint 24) e o callback
# POST /api/conectar do plugin WordPress. NUNCA committar. Sem essa chave,
# o scheduler não sobe e a conexão automática de site é desligada.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Magnific MCP
MAGNIFIC_MCP_URL=https://mcp.magnific.com/mcp

# Porta do sidecar (mantém 8000 pra compatibilidade com plugin WordPress v2)
PORT=8000

# Caminho onde ficam tokens OAuth e cache local (default: ./data/)
DATA_DIR=./data
