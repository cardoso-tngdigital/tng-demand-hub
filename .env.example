# =============================================================================
# TNG Demand Hub — Variáveis de Ambiente (TEMPLATE)
# =============================================================================
#
# Este arquivo serve apenas como documentação dos nomes das variáveis.
# Para uso real, copie este arquivo como `.env.local` e preencha os valores.
#
# IMPORTANTE: NUNCA commite o `.env.local` no Git. Ele já está no .gitignore.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Backend principal (banco + auth + storage + realtime)
# -----------------------------------------------------------------------------

# URL pública do projeto Supabase
# Onde encontrar: Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Chave PÚBLICA (anon). Pode ir no app desktop e no código. RLS protege.
# Onde encontrar: Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Reference ID do projeto (parte do URL antes de .supabase.co)
# Útil para chamadas à Supabase CLI
SUPABASE_PROJECT_REF=xxxxxxxxxxxxx

# Chave de SERVIÇO (service_role). ⚠️ NUNCA expor no client/frontend.
# Usar apenas em Edge Functions, scripts admin e ambiente de servidor.
# Onde encontrar: Settings → API → Project API keys → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Google Gemini — IA para extração estruturada das capturas
# -----------------------------------------------------------------------------

# Chave da API do Google AI Studio (https://aistudio.google.com)
# ⚠️ Esta chave fica APENAS no servidor (Edge Function do Supabase).
# Nunca embarcar no binário do app Tauri.
GEMINI_API_KEY=AIzaSy...

# Modelo padrão a ser usado nas chamadas
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Configurações do app
# -----------------------------------------------------------------------------

# Nome amigável da organização (aparece no app)
VITE_APP_ORG_NAME=TNG Digital

# Ambiente (development | staging | production)
NODE_ENV=development
