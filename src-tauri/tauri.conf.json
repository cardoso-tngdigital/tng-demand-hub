{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TNG Demand Hub",
  "version": "0.1.0",
  "identifier": "digital.tng.demandhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TNG Demand Hub",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "dragDropEnabled": false,
        "url": "index.html"
      },
      {
        "label": "capture",
        "title": "Captura rápida",
        "width": 640,
        "height": 420,
        "center": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "minimizable": false,
        "maximizable": false,
        "shadow": true,
        "dragDropEnabled": false,
        "url": "index.html#capture"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
