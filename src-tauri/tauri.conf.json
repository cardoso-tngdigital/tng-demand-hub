{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TNG Sites - Demandas",
  "version": "0.2.5",
  "identifier": "digital.tng.demandhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TNG Sites - Demandas",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "dragDropEnabled": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https: ipc: http://ipc.localhost; media-src 'self' data: blob: https:; connect-src 'self' ipc: http://ipc.localhost https://*.supabase.co wss://*.supabase.co https://github.com https://api.github.com https://objects.githubusercontent.com; worker-src 'self' blob:; frame-src 'self' blob: https://*.supabase.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../blog-backend/tng-blog-sidecar"
    ],
    "resources": [
      "../blog-backend/sidecar-vendor"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4REE1MTQzOThGOEUxMzYKUldRMjRmaVlRMUhhMkpSVWpOcDltbUNneGJHd1FEYXVJWmZGclZnbW95cUE5Z1c0eDJZc09WQmwK",
      "endpoints": [
        "https://github.com/cardoso-tngdigital/tng-demand-hub/releases/latest/download/latest.json"
      ]
    }
  }
}
